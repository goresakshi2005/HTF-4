OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini

GITHUB_TOKEN=
GITHUB_APP_ID=
# Option A (recommended): one-line escaped format
# GITHUB_APP_PRIVATE_KEY="-----BEGIN RSA PRIVATE KEY-----\nYOUR_KEY_LINE_1\nYOUR_KEY_LINE_2\n-----END RSA PRIVATE KEY-----\n"
#
# Option B (raw multiline): include full key exactly as downloaded
GITHUB_APP_PRIVATE_KEY="-----BEGIN RSA PRIVATE KEY-----
YOUR_KEY_LINE_1
YOUR_KEY_LINE_2
YOUR_KEY_LINE_3
-----END RSA PRIVATE KEY-----"

RISK_AUTO_FIX_THRESHOLD=0.80
RISK_HUMAN_REVIEW_THRESHOLD=0.90
MAX_AUTOFIX_FILES=5
MAX_AUTOFIX_HUNKS=20
MAX_REPAIR_ATTEMPTS=3
PATCH_STRATEGY=unified_diff
LLM_PATCH_MAX_CHARS=24000
FORCE_AUTOFIX_ALL=false
INDEXING_ENABLED=false
INDEXING_REBUILD=false
INDEXING_TOP_K=8
INDEXING_MAX_QUERY_CHARS=2000
INDEXING_MAX_QUERY_TOKENS=120
INDEXING_SKIP_SYMBOL_TOKEN_THRESHOLD=80
ALLOW_AUTOMERGE_LOW_RISK=true
REQUIRE_APPROVAL_FOR_RELEASE=false
LOG_LEVEL=INFO
BASE_BRANCH=main
WORKFLOW_NAME=
RUN_ID=

